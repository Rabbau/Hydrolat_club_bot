BOT_TOKEN=your_bot_token_here

#ADMIN_ID=123456789
ADMIN_ID=123456789
#SUPER_ADMIN_ID=123456789  # legacy single value
SUPER_ADMIN_IDS=123456789,987654321

# Target group/supergroup for automatic kick on subscription expiry
# Example supergroup id: -1001234567890
GROUP_CHAT_ID=-1001234567890
# Optional: multiple chats, comma-separated
# GROUP_CHAT_IDS=-1001234567890,-1009876543210

# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=tg_bot_db
DB_USER=tg_bot_user
DB_PASSWORD=tg_bot_password
DB_ECHO=false
